NODE_ENV=development
PORT=5000

# MongoDB (use Atlas URI for production)
MONGODB_URI=mongodb://localhost:27017/ratz-store

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRE=30d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:4200

# Admin credentials (for initial seed)
ADMIN_EMAIL=admin@ratzstore.lk
ADMIN_PASSWORD=changeme

# Email (Gmail App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Admin notification email (receives new order/message alerts, defaults to EMAIL_USER)
ADMIN_NOTIFICATION_EMAIL=admin@example.com
